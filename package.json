{
  "name": "stacks",
  "private": true,
  "type": "module",
  "description": "a trello clone",
  "license": "MIT",
  "sideEffects": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:e2e": "vite dev --config vite.config.e2e.ts",
    "netlify:dev": "netlify dev",
    "start": "node .output/server/index.mjs",
    "lint:fix": "pnpm exec biome check . --write --unsafe",
    "lint:check": "pnpm exec biome check .",
    "format": "pnpm exec biome format . --write",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "test:types": "tsgo --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "update:tsr": "pnpm add @tanstack/react-start@latest @tanstack/react-router@latest @tanstack/react-router-devtools@latest",
    "test": "playwright test --project=chromium",
    "test:ui": "playwright test --ui --project=chromium",
    "test:headed": "playwright test --headed --ui --project=chromium",
    "test:debug": "playwright test --debug --project=chromium",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.2.3",
    "@dnd-kit/react": "^0.4.0",
    "@neondatabase/neon-js": "0.6.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/functions": "^0.10.0",
    "@netlify/vite-plugin-tanstack-start": "^1.1.0",
    "@pigment-css/react": "^0.0.30",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@sentry/tanstackstart-react": "^10.53.1",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "date-fns": "^2.28.0",
    "dotenv": "^16.0.0",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-beautiful-dnd": "^13.1.0",
    "react-dom": "^19.2.0",
    "react-icons": "^4.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@clerk/testing": "^2.0.34",
    "@faker-js/faker": "^10.4.0",
    "@pigment-css/vite-plugin": "^0.0.30",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.2",
    "@types/node-uuid": "^0.0.29",
    "@types/react": "^19.1.9",
    "@types/react-beautiful-dnd": "^13.1.2",
    "@types/react-dom": "^19.1.7",
    "@typescript/native-preview": "7.0.0-dev.20260502.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "netlify-cli": "^17.38.1",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint:fix",
      "pnpm format"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "react-is": "18.3.1"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared"
    ]
  }
}
